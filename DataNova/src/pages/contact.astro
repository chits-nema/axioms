---
import BaseLayout from '../layout/BaseLayout.astro';

const seo = {
  title: 'Contact Axiom',
  description: 'Get in touch with the Axiom team for inquiries or support.',
};

const serif = { fontFamily: "'Instrument Serif', serif" };
---

<BaseLayout seo={seo} landingFonts={true}>
  <section class="mx-auto max-w-5xl px-6 pt-28 pb-24 sm:px-10">
    <h1 class="text-5xl leading-tight text-slate-950 sm:text-6xl md:text-7xl" style={serif}>Contact</h1>
    <p class="mt-4 text-lg text-slate-600 max-w-2xl">Get in touch with the Axiom team — we'd love to hear from you. Use this form to send a message and we'll respond within 2 business days.</p>

    <div class="mt-10 translucent-card rounded-2xl p-8">
      <form class="grid gap-4" action="#" method="post">
        <div>
          <label class="text-sm text-slate-700">Name</label>
          <input name="name" class="mt-1 block w-full rounded-md border border-slate-200 bg-white/80 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="text-sm text-slate-700">Email</label>
          <input name="email" type="email" class="mt-1 block w-full rounded-md border border-slate-200 bg-white/80 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="text-sm text-slate-700">Message</label>
          <textarea name="message" rows="6" class="mt-1 block w-full rounded-md border border-slate-200 bg-white/80 px-3 py-2 text-sm"></textarea>
        </div>
        <div>
          <button type="submit" class="rounded-full bg-teal-700 px-6 py-3 text-sm font-medium text-white">Send message</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
