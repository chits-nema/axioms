---
export const prerender = true;
import BaseLayout from '@layout/BaseLayout.astro';
import { apiBaseUrl, backendRoutes } from '@/lib/api';

const mode = Astro.url.searchParams.get('mode');
const isCatalogue = mode === 'catalogue';
const selectedModeLabel = isCatalogue ? 'Catalogue RAG' : 'Upload quotations';
const selectedModeDescription = isCatalogue
  ? 'Start from catalogue context and surface a shortlist before weighting the decision.'
  : 'Start with uploaded quotations and convert vendor documents into structured evidence.';
---

<BaseLayout
  seo={{
    title: 'Decision Workspace - Axioms',
    description: 'Choose a procurement evaluation track and run the Axioms decision workflow.',
  }}
>
  <section class="min-h-screen bg-off-white px-4 pt-40 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-[85rem] gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold tracking-[0.22em] text-teal-800 uppercase">
          Decision workspace
        </p>
        <h1 class="mt-3 text-4xl font-semibold text-slate-950 md:text-6xl">
          {selectedModeLabel}
        </h1>
        <p class="mt-5 max-w-2xl text-slate-600">
          {selectedModeDescription} The rest of the workflow stays shared so every branch ends in a
          defensible recommendation.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/decision?mode=quotations"
            class={`rounded-lg border px-5 py-3 text-center font-medium transition ${
              isCatalogue
                ? 'border-slate-200 bg-white text-slate-700 hover:border-teal-300 hover:text-teal-900'
                : 'border-teal-700 bg-teal-700 text-white'
            }`}
          >
            Upload quotations
          </a>
          <a
            href="/decision?mode=catalogue"
            class={`rounded-lg border px-5 py-3 text-center font-medium transition ${
              isCatalogue
                ? 'border-teal-700 bg-teal-700 text-white'
                : 'border-slate-200 bg-white text-slate-700 hover:border-teal-300 hover:text-teal-900'
            }`}
          >
            Use catalogue
          </a>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 p-5">
            <p class="font-semibold text-slate-950">Track A: Quotations</p>
            <p class="mt-2 text-sm text-slate-600">
              Upload vendor PDFs and normalise them for scoring.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-5">
            <p class="font-semibold text-slate-950">Track B: Catalogue</p>
            <p class="mt-2 text-sm text-slate-600">
              Use catalogue RAG when there are no quotations.
            </p>
          </div>
        </div>

        <div class="mt-8 rounded-2xl border border-teal-100 bg-teal-50 p-5">
          <p class="text-sm font-semibold tracking-[0.18em] text-teal-800 uppercase">
            Backend connection
          </p>
          <p class="mt-2 text-sm text-slate-600">
            This workspace is wired to {apiBaseUrl} and the FastAPI routes below.
          </p>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            {backendRoutes.map(route => (
              <div class="rounded-2xl border border-teal-100 bg-white p-4">
                <p class="text-xs font-semibold tracking-[0.18em] text-teal-800 uppercase">
                  {route.label}
                </p>
                <p class="mt-1 text-sm font-medium text-slate-950">{route.path}</p>
                <p class="mt-1 text-sm text-slate-600">{route.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="rounded-[1.75rem] border border-teal-100 bg-teal-50 p-8">
        <p class="text-sm font-semibold tracking-[0.22em] text-teal-800 uppercase">
          Selected branch
        </p>
        <h2 class="mt-3 text-3xl font-semibold text-slate-950">{selectedModeLabel}</h2>
        <p class="mt-4 text-slate-600">
          This selection can be used to open the appropriate branch of the shared workflow,
          keeping the entry screen simple while preserving a direct route into the task.
        </p>

        <div class="mt-6 rounded-2xl border border-teal-200 bg-white p-5">
          <p class="text-sm font-semibold text-teal-900">What happens next</p>
          <ol class="mt-3 space-y-2 text-sm text-slate-600">
            <li>1. Capture the decision context.</li>
            <li>2. Discover criteria and weighting.</li>
            <li>3. Evaluate options and explain the tradeoffs.</li>
          </ol>
        </div>

        <div class="mt-6 rounded-2xl border border-teal-200 bg-white p-5">
          <p class="text-sm font-semibold text-teal-900">Frontend responsibility</p>
          <p class="mt-2 text-sm text-slate-600">
            Use DataNova to host the UI and call the backend routes; keep lovable as a design
            reference only.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
