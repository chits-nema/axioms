---
import Button from '@ui/Button.astro';
---

<section class="relative isolate overflow-hidden bg-slate-950 text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(45,212,191,0.18),_transparent_32%),radial-gradient(circle_at_80%_20%,_rgba(255,255,255,0.08),_transparent_26%),linear-gradient(180deg,_#05202b_0%,_#020617_100%)]" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-[url('/social.png')] bg-cover bg-center opacity-5 mix-blend-screen" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-[85rem] px-4 pt-32 pb-14 sm:px-6 lg:px-8 lg:pt-40 lg:pb-20">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold tracking-[0.28em] text-teal-300 uppercase">
          Axioms procurement analyst
        </p>
        <h1 class="mt-4 max-w-4xl text-5xl leading-[0.95] font-semibold tracking-tight text-white md:text-7xl">
          AI procurement decisions you can defend.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-200 md:text-xl">
          Compare vendor quotations or explore trusted catalogue options. Axioms normalises inputs,
          discovers decision criteria, weighs tradeoffs, and produces an explainable recommendation.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button
            href="/decision?mode=quotations"
            variant="primary"
            className="bg-teal-400 text-slate-950 hover:bg-teal-300 focus:bg-teal-300"
          >
            Upload Quotations
          </Button>
          <Button
            href="/decision?mode=catalogue"
            variant="secondary"
            className="border-white/60 text-white hover:border-white hover:bg-white hover:text-slate-950"
          >
            Use Catalogue
          </Button>
        </div>

        <div class="mt-10 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm">
            <p class="text-xs font-semibold tracking-[0.18em] text-teal-300 uppercase">
              Step 1
            </p>
            <p class="mt-2 text-sm text-slate-200">Understand options</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm">
            <p class="text-xs font-semibold tracking-[0.18em] text-teal-300 uppercase">
              Step 2
            </p>
            <p class="mt-2 text-sm text-slate-200">Discover priorities</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm">
            <p class="text-xs font-semibold tracking-[0.18em] text-teal-300 uppercase">
              Step 3
            </p>
            <p class="mt-2 text-sm text-slate-200">Defend recommendation</p>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-8 rounded-[2rem] bg-teal-500/15 blur-3xl" aria-hidden="true"></div>
        <div class="relative rounded-[2rem] border border-white/10 bg-white/8 p-4 shadow-2xl backdrop-blur-xl">
          <div class="rounded-[1.5rem] border border-slate-200/70 bg-slate-50 p-5 text-slate-900 shadow-xl">
            <div class="flex flex-wrap items-start justify-between gap-4 border-b border-slate-200 pb-4">
              <div>
                <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">
                  Recommended vendor
                </p>
                <h2 class="mt-1 text-2xl font-semibold text-slate-950">Vendor B</h2>
                <p class="mt-1 text-sm text-slate-500">Aligned to criteria, risk, and strategic fit</p>
              </div>
              <div class="rounded-2xl bg-teal-100 px-4 py-3 text-right">
                <p class="text-xs font-semibold text-teal-800">Confidence</p>
                <p class="text-3xl font-semibold tracking-tight text-teal-950">87%</p>
              </div>
            </div>

            <div class="mt-5 grid gap-3">
              {
                [
                  ['Functional fit', '40%', 'w-[40%]'],
                  ['Risk profile', '30%', 'w-[30%]'],
                  ['Strategic fit', '20%', 'w-[20%]'],
                  ['Financial fit', '10%', 'w-[10%]'],
                ].map(([label, value, width]) => (
                  <div>
                    <div class="mb-1 flex justify-between text-sm font-medium text-slate-700">
                      <span>{label}</span>
                      <span>{value}</span>
                    </div>
                    <div class="h-2 rounded-full bg-slate-100">
                      <div class={`h-2 rounded-full bg-gradient-to-r from-teal-500 to-teal-700 ${width}`}></div>
                    </div>
                  </div>
                ))
              }
            </div>

            <div class="mt-6 grid gap-3 md:grid-cols-2">
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <p class="text-sm font-semibold text-slate-950">Why Vendor B wins</p>
                <ul class="mt-3 space-y-2 text-sm text-slate-600">
                  <li>Strong integrations</li>
                  <li>GDPR compliant</li>
                  <li>Best strategic fit</li>
                </ul>
              </div>
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <p class="text-sm font-semibold text-slate-950">Tradeoff</p>
                <ul class="mt-3 space-y-2 text-sm text-slate-600">
                  <li>12% higher subscription cost</li>
                  <li>Slightly slower migration</li>
                  <li>Still wins on weighted score</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm">
            <p class="text-sm font-semibold text-white">Inputs</p>
            <p class="mt-1 text-sm text-slate-300">Quotations, catalogue data, and vendor context</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm">
            <p class="text-sm font-semibold text-white">Analysis</p>
            <p class="mt-1 text-sm text-slate-300">Requirements discovery and weighted scoring</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm">
            <p class="text-sm font-semibold text-white">Output</p>
            <p class="mt-1 text-sm text-slate-300">Explainable recommendation and defensible tradeoffs</p>
          </div>
        </div>
      </div>
    </div>

    <div id="tracks" class="mt-16 grid gap-5 lg:grid-cols-2">
      <a
        href="/decision?mode=quotations"
        class="group rounded-[1.5rem] border border-white/10 bg-white/6 p-6 transition duration-300 hover:-translate-y-1 hover:border-teal-300/40 hover:bg-white/10 hover:shadow-2xl"
      >
        <p class="text-sm font-semibold tracking-[0.18em] text-teal-300 uppercase">Track A</p>
        <h3 class="mt-3 text-2xl font-semibold text-white">Upload vendor quotations</h3>
        <p class="mt-3 max-w-xl text-slate-300">
          Normalise uploaded PDFs into structured vendor facts, then score each quote against the
          same criteria and tradeoffs.
        </p>
        <p class="mt-5 text-sm font-medium text-teal-300 group-hover:text-teal-200">
          Start with quotations
        </p>
      </a>

      <a
        href="/decision?mode=catalogue"
        class="group rounded-[1.5rem] border border-white/10 bg-white/6 p-6 transition duration-300 hover:-translate-y-1 hover:border-teal-300/40 hover:bg-white/10 hover:shadow-2xl"
      >
        <p class="text-sm font-semibold tracking-[0.18em] text-teal-300 uppercase">Track B</p>
        <h3 class="mt-3 text-2xl font-semibold text-white">Use catalogue RAG</h3>
        <p class="mt-3 max-w-xl text-slate-300">
          Start without quotations. Retrieve relevant vendor context from the catalogue and run it
          through the same metrics and reporting pipeline.
        </p>
        <p class="mt-5 text-sm font-medium text-teal-300 group-hover:text-teal-200">
          Explore the catalogue
        </p>
      </a>
    </div>
  </div>
</section>
